BOT_TOKEN=your_telegram_bot_token
BOT_TIMEZONE=Asia/Vladivostok
DB_PATH=contracts.db

# File storage. Keep local for development unless S3 credentials are configured.
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_LOCAL_ROOT=uploads
FILE_STORAGE_REDIRECT_SIGNED_URL=1
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET=
S3_REGION=ru-central1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=crm/dev
S3_PRESIGNED_URL_TTL_SECONDS=300
S3_ADDRESSING_STYLE=path

# Daily 1C bank statement auto-import via IMAP.
BANK_MAIL_OWNER_CHAT_ID=329457823
BANK_MAIL_IMAP_HOST=imap.mail.ru
BANK_MAIL_IMAP_PORT=993
BANK_MAIL_LOGIN=felis.bank.statement@mail.ru
BANK_MAIL_PASSWORD=mail_ru_app_password
BANK_MAIL_FOLDER=INBOX
BANK_MAIL_LIMIT=20
BANK_MAIL_SEARCH=ALL
BANK_MAIL_MARK_SEEN=1
BANK_MAIL_AUTO_IMPORT_ENABLED=1
BANK_MAIL_DAILY_TIME=08:30
BANK_MAIL_RUN_ON_STARTUP=1
